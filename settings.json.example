{
  "_comment": "Minimal example showing the SessionStart + SessionEnd hooks clexo uses. The recommended way to install these is `clexo install` (or `clexo install-hooks`), which wires them into ~/.claude/settings.json and backs the file up first. This file is for reference / manual merging. Assumes `clexo` is on your PATH (pipx/uv put it there). JSON does not support comments; remove the _comment keys before use.",

  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear",
        "_comment": "Restores the pending session snapshot on a fresh claude startup or after /clear",
        "hooks": [
          {
            "type": "command",
            "command": "clexo session-start"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "_comment": "Keeps the FTS index fresh in the background after each session",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'clexo sync >> /tmp/clexo-sync.log 2>&1 &'"
          }
        ]
      }
    ]
  }
}
